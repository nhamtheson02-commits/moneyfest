generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Lead {
  id          String           @id @default(cuid())
  name        String
  email       String
  phone       String?
  source      String           @default("website")
  note        String?
  consentGiven Boolean          @default(false)
  consentAt    DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  downloads   EbookDownload[]
  toolResults ToolResult[]
  submissions FormSubmission[]

  @@index([email])
  @@index([createdAt])
}

model Ebook {
  id          String          @id @default(cuid())
  title       String
  slug        String          @unique
  subtitle    String
  description String
  fileUrl     String?
  coverColor  String          @default("obsidian")
  level       String          @default("Beginner")
  pages       Int             @default(24)
  isFree      Boolean         @default(true)
  isFeatured  Boolean         @default(false)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  downloads   EbookDownload[]
}

model EbookDownload {
  id        String   @id @default(cuid())
  leadId    String
  ebookId   String
  createdAt DateTime @default(now())
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  ebook     Ebook    @relation(fields: [ebookId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([leadId])
  @@index([ebookId])
}

model Post {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  excerpt     String
  content     String
  coverColor  String    @default("midnight")
  readTime    Int       @default(5)
  isFeatured  Boolean   @default(false)
  publishedAt DateTime  @default(now())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  categoryId  String
  category    Category  @relation(fields: [categoryId], references: [id])
  tags        Tag[]

  @@index([publishedAt])
  @@index([categoryId])
}

model Category {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  posts       Post[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Tag {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  posts     Post[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ConsultationRequest {
  id            String   @id @default(cuid())
  name          String
  email         String
  phone         String
  message       String
  financialGoal String
  consentGiven  Boolean  @default(false)
  consentAt     DateTime?
  status        String   @default("new")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([createdAt])
  @@index([email])
}

model ToolResult {
  id        String   @id @default(cuid())
  toolType  String
  email     String?
  leadId    String?
  score     Int?
  result    String
  payload   String
  createdAt DateTime @default(now())
  lead      Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([toolType])
  @@index([createdAt])
}

model FormSubmission {
  id        String   @id @default(cuid())
  formType  String
  leadId    String?
  payload   String
  createdAt DateTime @default(now())
  lead      Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([formType])
  @@index([createdAt])
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  group     String   @default("general")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
